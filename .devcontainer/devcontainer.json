{
    "name": "ESP32-FIDO Dev",
    "build": { "dockerfile": "Dockerfile" },
    "customizations": {
        "vscode": {
            "extensions": [
                "platformio.platformio-ide",
                "ms-vscode.cpptools",
                "ms-python.python",
                "saoudrizwan.claude-dev"
            ],
            "settings": {
                "C_Cpp.default.compilerPath": "/home/vscode/.platformio/packages/toolchain-xtensa-esp32s3/bin/xtensa-esp32s3-elf-g++",
                "C_Cpp.default.intelliSenseMode": "gcc-x64",
                "C_Cpp.default.defines": [
                    "ESP32S3",
                    "XIAO_ESP32S3",
                    "ARDUINO",
                    "ARDUINO_USB_MODE=0",
                    "ARDUINO_USB_CDC_ON_BOOT=0",
                    "BOARD_HAS_PSRAM"
                ],
                "files.associations": {
                    "*.ino": "cpp"
                }
            }
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:1": {}
    },
    "postStartCommand": "nohup ollama serve > /tmp/ollama.log 2>&1 &",
    // 実機フラッシュ時のUSBデバイスアクセス用（PlatformIO Remote Agent推奨）
    // XIAO ESP32-S3はUSB-CでPCに直結、/dev/cu.usbmodem* または /dev/ttyACM0 が現れる
    // "runArgs": [
        // "--device=/dev/ttyACM0",
        // "--device=/dev/ttyUSB0"
    // ],
    "remoteUser": "vscode"
}